# ===========================
# Server Environment Variables
# ===========================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server port (default: 5000)
PORT=5000

# Frontend URL (for CORS — allowing the React app to call this API)
CLIENT_URL=http://localhost:5173

# MongoDB connection string
# Local: mongodb://localhost:27017/sonicscript
# Atlas: mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/sonicscript
MONGODB_URI=mongodb://localhost:27017/sonicscript

# Deepgram API Key (get yours free at https://deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
